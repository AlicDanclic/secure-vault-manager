{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "electron"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "electron.vite.config.ts",
    "../src/main/**/*.ts",
    "../src/preload/**/*.ts",
    "../src/shared/**/*.ts"
  ]
}
