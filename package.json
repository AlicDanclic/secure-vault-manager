{
  "name": "secure-vault-manager",
  "version": "1.1.0",
  "description": "A serious, dark-themed password manager built with Electron.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --config config/electron.vite.config.ts",
    "start": "electron-vite preview --config config/electron.vite.config.ts",
    "serve": "node tools/server.js",
    "typecheck": "tsc -p config/tsconfig.node.json && tsc -p config/tsconfig.web.json",
    "build": "npm run typecheck && electron-vite build --config config/electron.vite.config.ts",
    "dist": "npm run build && electron-builder --config config/electron-builder.yml"
  },
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  }
}
